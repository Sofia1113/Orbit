{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orbit.local/task-packet.schema.json",
  "title": "Orbit Task Packet",
  "type": "object",
  "required": ["task_id", "stage", "task_spec", "scene", "files_in_scope", "acceptance", "out_of_scope", "next_action"],
  "properties": {
    "task_id": { "type": "string", "minLength": 1 },
    "parent_task_id": {
      "type": ["string", "null"],
      "description": "若为子任务，指向父任务 task_id（约定 <parent>.<n>）"
    },
    "density": { "enum": ["low", "medium", "high"] },
    "stage": { "type": "string", "minLength": 1 },
    "task_spec": { "type": "string", "minLength": 1 },
    "scene": {
      "type": "string",
      "minLength": 1,
      "description": "controller 必须完整注入的上下文摘要；子任务的 scene 由父任务摘要而来，禁止让 subagent 读文件补齐"
    },
    "files_in_scope": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "acceptance": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "out_of_scope": { "type": "array", "items": { "type": "string" } },
    "next_action": { "type": "string", "minLength": 1 },
    "spawn_subtask": {
      "type": "boolean",
      "default": false,
      "description": "planning 阶段标记该 step 应派发独立子任务"
    },
    "subtask_index": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "当为子任务时的序号（<parent>.<n> 中的 n）"
    },
    "dependency_mode": {
      "enum": ["parallel", "serial", "mixed", "none"],
      "default": "none",
      "description": "父 engine 规划的执行依赖模式；兄弟子任务并行前必须在 plan.md 说明安全理由"
    },
    "integration_role": {
      "enum": ["leaf", "parent_integration", "end_to_end_integration"],
      "default": "leaf",
      "description": "leaf=普通子任务；parent_integration=medium 父级集成验收；end_to_end_integration=high 父级端到端验收"
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": { "properties": { "subtask_index": { "type": "integer" } }, "required": ["subtask_index"] },
      "then": { "required": ["parent_task_id"] }
    }
  ]
}
