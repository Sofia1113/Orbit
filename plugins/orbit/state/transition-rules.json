{
  "density_stage_paths": {
    "low": ["triaged", "executing", "verifying", "completed"],
    "medium": ["triaged", "scoping", "executing", "verifying", "completed"],
    "high": ["triaged", "designing", "planning", "executing", "verifying", "reviewing", "completed"]
  },
  "event_stage_transitions": {
    "TRIAGE_DONE": {
      "low": "executing",
      "medium": "scoping",
      "high": "designing"
    },
    "SCOPE_DONE": "executing",
    "DESIGN_DONE": "planning",
    "PLAN_DONE": "executing",
    "EXECUTION_DONE": "verifying",
    "VERIFY_PASS": {
      "low": "completed",
      "medium": "completed",
      "high": "reviewing"
    },
    "VERIFY_FAIL": "repairing",
    "REVIEW_PASS": "completed",
    "REVIEW_FAIL": "repairing",
    "REPAIR_SUBMITTED": "verifying",
    "HANDOFF_SAVED": "handoff",
    "RESUME_RESTORED": "executing",
    "PAUSE": "paused",
    "CANCEL": "cancelled",
    "COMPLETE": "completed",
    "ESCALATE_DENSITY": {
      "medium": "designing",
      "low": "scoping"
    },
    "DOWNGRADE_DENSITY": {
      "high": "scoping",
      "medium": "executing"
    },
    "SUBTASK_SPAWNED": "executing",
    "SUBTASK_COMPLETED": "executing"
  },
  "verification_level_defaults": {
    "low": "optional",
    "medium": "required",
    "high": "required_plus_review"
  },
  "verification_level_rules": {
    "allow_upgrade": true,
    "allow_downgrade": false,
    "rationale": "风险上调永远允许（optional→required→required_plus_review），下调禁止，避免绕过独立评估"
  },
  "density_change_rules": {
    "escalate_requires": [
      "当前 stage 属于 scoping / designing / planning / executing",
      "必须更新 triage_result 并记录升级原因",
      "必须清理已无效的工件引用",
      "若在 executing 发起：必须先产出迁移 handoff（handoff_reason='escalate_density'，source_stage='executing'），再切换到新 density 的入口阶段（low→scoping，medium→designing）"
    ],
    "downgrade_requires": [
      "当前 stage 属于 scoping / designing / planning",
      "所有已产出工件仍对新 density 有效，或显式声明废弃",
      "首次执行者不变"
    ],
    "escalate_forbidden_after": ["verifying", "reviewing", "repairing"],
    "downgrade_forbidden_after": ["executing", "verifying", "reviewing", "repairing"]
  },
  "subtask_rules": {
    "parent_density_must_be": "high",
    "subtask_default_density": "medium",
    "task_id_convention": "<parent_task_id>.<n>",
    "require_injected_task_packet": true,
    "parent_cannot_complete_before_all_subtasks_verified": true
  },
  "evaluator_dispatch_rules": {
    "verify_requires_independent_evaluator": true,
    "review_requires_two_stage_evaluator": ["spec_compliance", "code_quality"],
    "evaluator_cannot_repair": true,
    "repair_owner_must_equal_first_executor": true,
    "consecutive_review_fail_limit": 2
  },
  "hard_rules": {
    "repairing_owner_must_equal_first_executor": true,
    "handoff_requires_next_action": true,
    "paused_requires_next_action": true,
    "single_in_progress_todo": true,
    "todo_write_is_source_of_truth_per_stage": true,
    "controller_must_inject_full_task_packet_to_subagent": true
  },
  "runtime_contract": {
    "preferred_state_schema": "plugins/orbit/state/runtime-state-lite.schema.json",
    "preferred_action_model": "todo_plus_next_action",
    "optional_action_model": "action_layer_for_high_planning_only",
    "gate_rules": "plugins/orbit/state/gates.json",
    "state_persistence_root": ".orbit/state/<task_id>/",
    "rules_authority_doc": "plugins/orbit/state/README.md"
  },
  "persistence_rules": {
    "runtime_file": ".orbit/state/<task_id>/runtime.json",
    "events_file": ".orbit/state/<task_id>/events.jsonl",
    "events_append_only": true,
    "events_is_recovery_source": false,
    "event_required_fields": ["ts", "event", "task_id", "stage_from", "stage_to", "owner"],
    "event_optional_fields": [
      "note", "evaluator_id", "repair_direction", "verify_fail_streak",
      "artifact", "handoff_reason", "downgrade_from", "escalate_from", "blocker_root_cause"
    ],
    "write_timing": "每个 skill 在回写 runtime.json 的同时 append 一行；一次 skill 运行内可追加多条",
    "subtask_events_isolated": true,
    "doc": "plugins/orbit/state/README.md#事件流append-only"
  }
}
