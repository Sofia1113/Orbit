{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orbit.local/task-state.schema.json",
  "title": "Orbit Task State",
  "type": "object",
  "required": [
    "task_id",
    "density",
    "stage",
    "status",
    "first_executor",
    "current_owner",
    "goal",
    "next_action",
    "artifacts",
    "last_event",
    "triage_result",
    "shared_context",
    "resume_context",
    "handoff_meta",
    "review_state",
    "verification_state",
    "rebuild_info"
  ],
  "properties": {
    "task_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string" },
    "density": { "enum": ["low", "medium", "high"] },
    "stage": {
      "enum": [
        "triaged",
        "scoping",
        "designing",
        "planning",
        "executing",
        "verifying",
        "reviewing",
        "repairing",
        "handoff",
        "paused",
        "completed",
        "cancelled"
      ]
    },
    "status": { "enum": ["active", "paused", "completed", "cancelled"] },
    "first_executor": { "type": "string", "minLength": 1 },
    "current_owner": { "type": "string", "minLength": 1 },
    "evaluator": { "type": "string" },
    "source_stage_before_handoff": { "type": ["string", "null"] },
    "last_active_stage": { "type": ["string", "null"] },
    "goal": { "type": "string", "minLength": 1 },
    "scope": { "type": "string" },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string" }
    },
    "artifacts": {
      "type": "object",
      "required": [
        "triage",
        "scope",
        "design",
        "plan",
        "execution",
        "verification",
        "review",
        "handoff",
        "task_packet"
      ],
      "properties": {
        "triage": { "type": ["string", "null"] },
        "scope": { "type": ["string", "null"] },
        "design": { "type": ["string", "null"] },
        "plan": { "type": ["string", "null"] },
        "execution": { "type": ["string", "null"] },
        "verification": { "type": ["string", "null"] },
        "review": { "type": ["string", "null"] },
        "handoff": { "type": ["string", "null"] },
        "task_packet": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "triage_result": {
      "type": "object",
      "required": [
        "intent_type",
        "complexity_score",
        "density_reasons",
        "routing_confidence",
        "selected_workflow",
        "required_stages",
        "verification_level",
        "scores",
        "hard_rules_triggered",
        "request_summary",
        "workflow_path",
        "required_artifacts",
        "why_not_lower"
      ],
      "properties": {
        "intent_type": {
          "enum": ["feature", "bugfix", "refactor", "investigation", "recovery", "maintenance"]
        },
        "complexity_score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "density_reasons": { "type": "array", "items": { "type": "string" } },
        "routing_confidence": { "enum": ["high", "medium", "low"] },
        "selected_workflow": { "enum": ["low", "medium", "high"] },
        "required_stages": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "verification_level": { "enum": ["optional", "required", "required_plus_review"] },
        "scores": {
          "type": "object",
          "required": [
            "scope_breadth",
            "requirement_clarity",
            "design_uncertainty",
            "state_recovery_need",
            "validation_risk",
            "coordination_complexity"
          ],
          "properties": {
            "scope_breadth": { "type": "integer", "minimum": 0, "maximum": 3 },
            "requirement_clarity": { "type": "integer", "minimum": 0, "maximum": 3 },
            "design_uncertainty": { "type": "integer", "minimum": 0, "maximum": 3 },
            "state_recovery_need": { "type": "integer", "minimum": 0, "maximum": 2 },
            "validation_risk": { "type": "integer", "minimum": 0, "maximum": 3 },
            "coordination_complexity": { "type": "integer", "minimum": 0, "maximum": 3 }
          },
          "additionalProperties": false
        },
        "hard_rules_triggered": { "type": "array", "items": { "type": "string" } },
        "request_summary": { "type": "string", "minLength": 1 },
        "workflow_path": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "required_artifacts": { "type": "array", "items": { "type": "string" } },
        "why_not_lower": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "action_layer": {
      "type": ["object", "null"],
      "description": "高复杂度 planning 阶段可选增强层；v1 最小运行时不依赖该字段。",
      "required": ["actions", "current_action_id", "next_action_id"],
      "properties": {
        "actions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "title",
              "description",
              "status",
              "kind",
              "owner",
              "stage",
              "depends_on",
              "produces",
              "acceptance_signal",
              "source",
              "updated_at"
            ],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "title": { "type": "string", "minLength": 1 },
              "description": { "type": "string" },
              "status": { "enum": ["pending", "ready", "in_progress", "blocked", "done", "cancelled"] },
              "kind": { "enum": ["implementation", "verification", "review", "handoff", "recovery"] },
              "owner": { "enum": ["executor", "evaluator", "skill"] },
              "stage": { "type": "string", "minLength": 1 },
              "depends_on": { "type": "array", "items": { "type": "string" } },
              "produces": { "type": "array", "items": { "type": "string" } },
              "acceptance_signal": { "type": "string", "minLength": 1 },
              "source": { "enum": ["plan", "repair_direction", "resume", "manual"] },
              "updated_at": { "type": "string", "minLength": 1 },
              "notes": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "current_action_id": { "type": ["string", "null"] },
        "next_action_id": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "shared_context": {
      "type": "object",
      "required": ["task_summary", "acceptance_contract", "current_focus"],
      "properties": {
        "task_summary": { "type": "string" },
        "acceptance_contract": { "type": "array", "items": { "type": "string" } },
        "current_focus": { "type": "string" }
      },
      "additionalProperties": false
    },
    "resume_context": {
      "type": "object",
      "required": ["resume_priority_used", "restored_from_artifacts", "resume_brief", "last_resume_at"],
      "properties": {
        "resume_priority_used": {
          "type": ["string", "null"],
          "enum": ["handoff", "review", "verification", "execution", "artifact_scan", "manual", null]
        },
        "restored_from_artifacts": { "type": "array", "items": { "type": "string" } },
        "resume_brief": { "type": "string" },
        "last_resume_at": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "handoff_meta": {
      "type": "object",
      "required": ["handoff_version", "handoff_status", "handoff_source_stage", "handoff_for_role", "summary_path", "handoff_reason"],
      "properties": {
        "handoff_version": { "type": "string", "minLength": 1 },
        "handoff_status": { "enum": ["none", "fresh", "stale", "consumed"] },
        "handoff_source_stage": { "type": ["string", "null"] },
        "handoff_for_role": { "type": ["string", "null"] },
        "summary_path": { "type": ["string", "null"] },
        "handoff_reason": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "review_state": {
      "type": "object",
      "required": ["review_required", "review_cycle"],
      "properties": {
        "review_required": { "type": "boolean" },
        "review_cycle": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "verification_state": {
      "type": "object",
      "required": ["verification_required", "verification_level", "verification_cycle", "last_verdict"],
      "properties": {
        "verification_required": { "type": "boolean" },
        "verification_level": { "enum": ["optional", "required", "required_plus_review"] },
        "verification_cycle": { "type": "integer", "minimum": 0 },
        "last_verdict": { "type": ["string", "null"], "enum": ["PASS", "FAIL", "INCOMPLETE", null] }
      },
      "additionalProperties": false
    },
    "rebuild_info": {
      "type": "object",
      "required": ["state_rebuildable", "rebuild_sources"],
      "properties": {
        "state_rebuildable": { "type": "boolean" },
        "rebuild_sources": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "decision_log": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "decision", "reason", "time", "status"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "time": { "type": "string", "minLength": 1 },
          "decision": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "status": { "enum": ["active", "superseded"] }
        },
        "additionalProperties": false
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text", "status", "time"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "text": { "type": "string", "minLength": 1 },
          "status": { "enum": ["open", "resolved"] },
          "time": { "type": "string", "minLength": 1 },
          "source_action_id": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text", "time"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "text": { "type": "string", "minLength": 1 },
          "time": { "type": "string", "minLength": 1 },
          "mitigation": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1,
      "description": "v1 最小运行时的唯一下一步动作；默认应与当前 todo 焦点保持一致。"
    },
    "last_event": {
      "enum": [
        "TASK_CREATED",
        "TRIAGE_RECORDED",
        "TRIAGE_DONE",
        "SCOPE_DONE",
        "DESIGN_DONE",
        "PLAN_DONE",
        "TASK_PACKET_EMITTED",
        "ACTION_STARTED",
        "ACTION_COMPLETED",
        "ACTION_BLOCKED",
        "EXECUTION_DONE",
        "VERIFY_PASS",
        "VERIFY_FAIL",
        "REVIEW_PASS",
        "REVIEW_FAIL",
        "REPAIR_SUBMITTED",
        "BLOCKER_ADDED",
        "BLOCKER_RESOLVED",
        "RISK_ADDED",
        "DECISION_RECORDED",
        "HANDOFF_VALIDATED",
        "HANDOFF_SAVED",
        "RESUME_RESTORED",
        "STATE_REBUILT",
        "PAUSE",
        "CANCEL",
        "COMPLETE"
      ]
    },
    "repair_direction": {
      "type": ["string", "null"],
      "description": "仅在验证或审查失败后进入 repairing 时使用的修复方向。"
    },
    "todo": {
      "description": "v1 最小运行时的主动作模型；任意时刻只允许一个 todo 为 in_progress。",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text", "status"],
        "properties": {
          "id": { "type": "string" },
          "text": { "type": "string" },
          "status": { "enum": ["pending", "in_progress", "done"] }
        },
        "additionalProperties": false
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "stage": { "const": "repairing" }
        }
      },
      "then": {
        "required": ["current_owner", "first_executor", "repair_direction"]
      }
    },
    {
      "if": {
        "properties": {
          "stage": { "enum": ["handoff", "paused"] }
        }
      },
      "then": {
        "required": ["next_action"]
      }
    },
    {
      "if": {
        "properties": {
          "stage": { "enum": ["completed", "cancelled"] }
        }
      },
      "then": {
        "properties": {
          "todo": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "status": { "enum": ["pending", "done"] }
              }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}